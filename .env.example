# ============================================================
#  Mina Command Center — configuration & API credentials
#
#  HOW TO USE:
#    1. Copy this file and rename the copy to ".env"
#    2. Replace the DUMMY_* values with your real API keys
#    3. Any value still starting with "DUMMY" makes that source
#       use test data instead of calling the live API.
#  You can switch the sources on one at a time.
# ============================================================

# Which port the web server listens on. Open http://localhost:4000
PORT=4000

# When the daily automatic sync runs (24-hour clock, IST).
SYNC_HOUR=1
SYNC_MINUTE=1

# ---- LIVE TESTING WITHOUT REAL KEYS ----
# true  = any source without a real key uses a FREE, no-key public API
#         (real network calls, live-changing numbers) so you can see the
#         dashboard running "live" right now.
# false = sources without a real key use fixed sample data instead.
# >>> Set this to false once you have added the real keys below. <<<
DEMO_LIVE=true

# ---- Free Demo API Keys (for live testing/demo) ----
# To test real API key integration without Meta or Google developer accounts,
# sign up for a free key from WeatherAPI (https://www.weatherapi.com/)
# or ExchangeRate-API (https://www.exchangerate-api.com/).
# Set them below. If they start with "DUMMY", the system will fall back to Open-Meteo.
DEMO_WEATHER_API_KEY=DUMMY_weather_api_key
DEMO_EXCHANGERATE_API_KEY=DUMMY_exchangerate_api_key

# ---- Meta Ads (Marketing API) ----
# Get these from https://developers.facebook.com  -> your app -> Marketing API
META_ACCESS_TOKEN=DUMMY_meta_access_token
META_AD_ACCOUNT_ID=act_DUMMY000000000
META_API_VERSION=v21.0

# ---- Google Ads API ----
GOOGLE_ADS_DEVELOPER_TOKEN=DUMMY_google_dev_token
GOOGLE_ADS_CLIENT_ID=DUMMY_google_client_id
GOOGLE_ADS_CLIENT_SECRET=DUMMY_google_client_secret
GOOGLE_ADS_REFRESH_TOKEN=DUMMY_google_refresh_token
GOOGLE_ADS_CUSTOMER_ID=DUMMY0000000000
GOOGLE_ADS_LOGIN_CUSTOMER_ID=DUMMY0000000000

# ---- Shopify (Admin API) ----
SHOPIFY_STORE_DOMAIN=minaeyebrowtints.myshopify.com
SHOPIFY_ADMIN_TOKEN=DUMMY_shpat_token
SHOPIFY_API_VERSION=2025-01

# ---- Shiprocket (API) ----
SHIPROCKET_EMAIL=DUMMY_email@example.com
SHIPROCKET_PASSWORD=DUMMY_password
