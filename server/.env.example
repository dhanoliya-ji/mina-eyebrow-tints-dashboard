# ============================================================
#  Mina Command Center — API credentials
#  Copy this file to `.env` and replace the DUMMY_* values with
#  real keys. Any value still starting with "DUMMY" makes that
#  connector serve mock data instead of calling the live API.
#  You can switch sources on one at a time.
# ============================================================

PORT=4000
# How often to re-pull the rolling 7-day window (cron, IST).
# Default: every day at 07:30 AM. Also runs once on startup.
SYNC_CRON=30 7 * * *
TZ=Asia/Kolkata

# Live testing without real keys: true routes sources lacking real
# credentials through a free, no-key public API (real network calls).
# Set to false once real keys are in place.
DEMO_LIVE=true

# ---- Meta Ads (Marketing API) ----
# Get from https://developers.facebook.com/ → your app → Marketing API
META_ACCESS_TOKEN=DUMMY_meta_access_token
META_AD_ACCOUNT_ID=act_DUMMY000000000
META_API_VERSION=v21.0

# ---- Google Ads API ----
GOOGLE_ADS_DEVELOPER_TOKEN=DUMMY_google_dev_token
GOOGLE_ADS_CLIENT_ID=DUMMY_google_client_id
GOOGLE_ADS_CLIENT_SECRET=DUMMY_google_client_secret
GOOGLE_ADS_REFRESH_TOKEN=DUMMY_google_refresh_token
GOOGLE_ADS_CUSTOMER_ID=DUMMY0000000000
GOOGLE_ADS_LOGIN_CUSTOMER_ID=DUMMY0000000000

# ---- Shopify (Admin API) ----
SHOPIFY_STORE_DOMAIN=minaeyebrowtints.myshopify.com
SHOPIFY_ADMIN_TOKEN=DUMMY_shpat_token
SHOPIFY_API_VERSION=2025-01

# ---- Shiprocket (API) ----
SHIPROCKET_EMAIL=DUMMY_email@example.com
SHIPROCKET_PASSWORD=DUMMY_password
